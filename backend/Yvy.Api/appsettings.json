{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=yvy;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  },
  "EntraId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<set-in-user-secrets>",
    "ClientId": "<set-in-user-secrets>",
    "Audience": "<api-app-id-uri-or-clientid>"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
